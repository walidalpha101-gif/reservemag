rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Media uploads
    match /articles/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /settings/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /seo/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
