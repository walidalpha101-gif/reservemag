rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. CORE AUTHENTICATION HELPERS
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return request.auth.token.email_verified == true; }
    
    // FUTURE-PROOF ADMIN CHECK:
    // Grants access if the user is the owner OR if they exist in the admins collection.
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == "walid.alpha101@gmail.com" || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ); 
    }

    // 2. THE GLOBAL ADMIN OVERRIDE
    // Admins get unrestricted read/write access to ALL current and future collections.
    match /{document=**} {
      allow read, write: if isAdmin() && isVerified();
    }

    // 3. PUBLIC ACCESS RULES
    // Allows normal website visitors to read content and submit forms.

    match /articles/{articleId} {
      allow read: if true;
    }

    match /categories/{categoryId} {
      allow read: if true;
    }

    match /authors/{authorId} {
      allow read: if true;
    }

    match /video_interviews/{videoId} {
      allow read: if true;
    }

    match /settings/{docId} {
      allow read: if true;
    }

    match /media/{assetId} {
      allow read: if true;
    }

    // Public submission endpoints (Create only, no read or delete)
    match /featured_requests/{requestId} {
      allow create: if true; 
    }

    match /newsletter_subscribers/{subscriberId} {
      allow create: if true;
    }
  }
}
